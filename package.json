{
  "name": "lingtai-agent-mail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ltmail": "bin/ltmail.mjs"
  },
  "scripts": {
    "check": "pnpm test && pnpm test:cli && pnpm typecheck",
    "test": "vitest run",
    "test:cli": "node tests/cli-login-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "ltmail": "node bin/ltmail.mjs",
    "live:agent-mail": "node scripts/live-agent-mail.mjs",
    "db:migrate:local": "wrangler d1 migrations apply lingtai-mail --local",
    "db:migrate:remote": "wrangler d1 migrations apply lingtai-mail --remote"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.10",
    "@cloudflare/workers-types": "^4.20260630.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.105.0"
  }
}
